#cloud-config
autoinstall:
    version: 1
    locale: en_US
    refresh-installer:
        update: false
    keyboard:
        layout: us
    ssh:
        install-server: true
        allow-pw: true
        disable_root: true
        ssh_quiet_keygen: true
        allow_public_ssh_keys: true
    storage:
        layout:
            name: direct
        swap:
            size: 0
    network:
        network:
            version: 2
            ethernets:
                ens18:
                    dhcp4: "no"
                    addresses:
                        - 192.168.1.249/24
                    routes:
                        - to: default
                          via: 192.168.1.1
                    nameservers:
                        addresses:
                            - 192.168.1.1
    user-data:
        package_upgrade: true
        timezone: Europe/Athens
        ssh_pwauth: true
        users:
            - name: admin
              groups:
                - adm
                - sudo
              lock-passwd: false
              sudo: ALL=(ALL) NOPASSWD:ALL
              shell: /bin/bash
              passwd: ENC[AES256_GCM,data:q/zih6v89Gz4Rnj/SgjHtSJ7+ulTQEq+UiOXiJdLeYL0k/sXDf3s3I7ttdG2R+D1H2Lvp16RllPw/D8xV/emVVnMZVGt0HoCa8jJ9jQxnSM8MyljQjjANZAOrY4yi+P2ZaN5,iv:aMHbDrut7ht4P2nuwzFLesPNOrmvhUWZ/xaNwSFJnFw=,tag:eIo0Uhe/m+aOCPRzjxTrXA==,type:str]
    packages:
        - qemu-guest-agent
        - sudo
        - vim
        - zip
        - unzip
sops:
