#cloud-config
autoinstall:
    version: 1
    locale: en_US
    refresh-installer:
        update: false
    keyboard:
        layout: us
    ssh:
        install-server: true
        allow-pw: true
        disable_root: true
        ssh_quiet_keygen: true
        allow_public_ssh_keys: true
    storage:
        layout:
            name: direct
        swap:
            size: 0
    network:
        network:
            version: 2
            ethernets:
                ens18:
                    dhcp4: "no"
                    addresses:
                        - 192.168.1.247/24
                    gateway4: 192.168.1.1
                    nameservers:
                        addresses:
                            - 192.168.1.1
    user-data:
        package_upgrade: true
        timezone: Europe/Athens
        ssh_pwauth: true
        users:
            - name: admin
              groups:
                - adm
                - sudo
              lock-passwd: false
              sudo: ALL=(ALL) NOPASSWD:ALL
              shell: /bin/bash
              passwd: ENC[AES256_GCM,data:f62ahOfSnC3U8f+7KdQv68ywFz7S7XAikD9d+OPJm5488UEGzAGz9dewGkVro0yR59z2yDuueNQM4T6gyFv3+ahyzlhV8htHQJCUEaWN/OSCSsnb3BB9pRcCYdGfiZruga/S,iv:Dg2aMXlE7T4Z9sOuHOzhypd9t1HOra9KiCXMOB/30J4=,tag:qaT8zRjGcmawW3f18x2ygw==,type:str]
    packages:
        - qemu-guest-agent
        - sudo
        - vim
        - zip
        - unzip
sops:
