#cloud-config
autoinstall:
    version: 1
    locale: en_US
    refresh-installer:
        update: false
    keyboard:
        layout: us
    ssh:
        install-server: true
        allow-pw: true
        disable_root: true
        ssh_quiet_keygen: true
        allow_public_ssh_keys: true
    storage:
        layout:
            name: direct
        swap:
            size: 0
    network:
        network:
            version: 2
            ethernets:
                ens18:
                    dhcp4: "no"
                    addresses:
                        - 192.168.1.248/24
                    routes:
                        - to: default
                          via: 192.168.1.1
                    nameservers:
                        addresses:
                            - 192.168.1.1
    user-data:
        package_upgrade: true
        timezone: Europe/Athens
        ssh_pwauth: true
        users:
            - name: admin
              groups:
                - adm
                - sudo
              lock_passwd: false
              sudo: ALL=(ALL) NOPASSWD:ALL
              shell: /bin/bash
              passwd: ENC[AES256_GCM,data:W2zfAhXBMrpBbA00rNXsKecTOZ/A3hZwnN8WoweYz2Yla7gS14af3RLYboFs4OfCQvlePrA4k2957BwLL3ZWORTEdRaIXArSJ/XQ8fCPhMUlz2EDunBSHNJS/Rg1aOPVnAuc,iv:jwSnkF+gKkEcJQzxTmdPowjlkRN2PcwDhvDPnWgVhfo=,tag:NbMTCHbz9kFq7dZj1QFbQg==,type:str]
    packages:
        - qemu-guest-agent
        - sudo
        - vim
        - zip
        - unzip
sops:
