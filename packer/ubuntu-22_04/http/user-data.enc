#cloud-config
autoinstall:
    version: 1
    locale: en_US
    refresh-installer:
        update: false
    keyboard:
        layout: us
    ssh:
        install-server: true
        allow-pw: true
        disable_root: true
        ssh_quiet_keygen: true
        allow_public_ssh_keys: true
    storage:
        layout:
            name: direct
        swap:
            size: 0
    network:
        network:
            version: 2
            ethernets:
                ens18:
                    dhcp4: "no"
                    addresses:
                        - 192.168.1.246/24
                    gateway4: 192.168.1.1
                    nameservers:
                        addresses:
                            - 192.168.1.1
    user-data:
        package_upgrade: true
        timezone: Europe/Athens
        ssh_pwauth: true
        users:
            - name: admin
              groups:
                - adm
                - sudo
              lock-passwd: false
              sudo: ALL=(ALL) NOPASSWD:ALL
              shell: /bin/bash
              passwd: ENC[AES256_GCM,data:T3jiMc4Sb72tZ0/rhfR7gZB2CSY9xY8FhKvbSY9Ht2AbcTXl6VkOWGrOUVog6Ywu228cfSH6/iAQJQ9LSLxfaGf7Z2xXxLn3OZyLMf6GfPyPdyz+/Esa+EMOnnlZN4em7RGI,iv:2b+YFZDn/7PwAOUlMlY/+ykp1shclcmkRN69SA6MgWc=,tag:Wn2xoXqM00JylS2S8y4dnA==,type:str]
    packages:
        - qemu-guest-agent
        - sudo
        - vim
        - zip
        - unzip
sops:
